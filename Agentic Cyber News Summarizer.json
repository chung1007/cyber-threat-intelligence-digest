      "name": "Extract HTML"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const match = $json.data.match(\n  /<script id=\"__NEXT_DATA__\" type=\"application\\/json\"[^>]*>(.*?)<\\/script>/s\n);\n\nif (!match) {\n  throw new Error(\"Application JSON script not found\");\n}\n\nconst nextData = JSON.parse(match[1]);\n\nconst article =\n  nextData?.props?.pageProps?.page?.data?.[0]?.article;\n\nif (!article) {\n  throw new Error(\"Article object not found\");\n}\n\nconst bodyJson = JSON.parse(article.body);\n\nconst content = bodyJson.blocks\n  .map(block => {\n\tif (block.type === \"paragraph\") {\n  \treturn block.data?.text || \"\";\n\t}\n\n\tif (block.type === \"header\") {\n  \treturn \"\\n\" + (block.data?.text || \"\") + \"\\n\";\n\t}\n\n\treturn \"\";\n  })\n  .filter(Boolean)\n  .join(\"\\n\\n\");\n\nreturn {\n  title: article.title,\n  date: article.date,\n  content: content.slice(0, 4000)\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        -512
      ],
      "id": "204240bf-1463-4ba3-9fe8-faa90ace54e5",
