      "id": "82d5f424-20a2-479e-82b4-95fe0fe3d1d3",
      "name": "Extract Ollama Response"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json.data || [];\n\n// Keep only valid Ollama responses\nconst articles = data.filter(\n  article =>\n\tarticle &&\n\tarticle.response &&\n\ttypeof article.response === 'string' &&\n\tarticle.response.trim() !== ''\n);\n\n// Prevent downstream nodes from running\nif (articles.length === 0) {\n  return [];\n}\n\nlet html = `\n<h1>Cyber Threat Intelligence Digest</h1>\n<p>Generated by n8n + Ollama</p>\n`;\n\nfor (const article of articles) {\n  html += `\n  <div style=\"border:1px solid #ddd;padding:15px;margin-bottom:20px;\">\n\t<pre style=\"white-space:pre-wrap;font-family:Arial;\">\n${article.response}\n\t</pre>\n  </div>\n  `;\n}\n\nreturn [\n  {\n\tjson: {\n  \tsubject: `Daily Cyber Intelligence Digest`,\n  \thtml\n\t}\n  }\n];\n"
      },
